# Backend (Go + Gin) configuration.

# HTTP port (Railway sets PORT automatically).
PORT=8082

# Postgres connection string. Leave empty to run with in-memory demo data.
# Railway Postgres exposes this as DATABASE_URL.
DATABASE_URL=

# CORS: comma-separated origins, or "*" for any (dev).
ALLOWED_ORIGINS=http://localhost:3002

# Amazon Bedrock (server-side LLM). Empty → AI endpoints return mock text.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0
